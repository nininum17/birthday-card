<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday!</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    <style>
        body { font-family: 'Prompt', sans-serif; }
        .glass-effect {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
        }
        .reveal-text {
            display: none;
            animation: fadeIn 1s ease-in forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-indigo-100 via-purple-100 to-pink-100 min-h-screen flex items-center justify-center p-4">

    <div class="glass-effect max-w-md w-full rounded-3xl shadow-2xl overflow-hidden text-center p-8 transition-transform duration-300 hover:scale-105">
        
        <div class="relative w-40 h-40 mx-auto mb-6">
            <img 
                src="https://images.unsplash.com/photo-1558636508-e0db3814bd1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" 
                alt="Birthday Person" 
                class="rounded-full object-cover w-full h-full border-4 border-white shadow-lg"
            >
            <div class="absolute bottom-0 right-0 bg-yellow-400 text-white rounded-full p-2 text-xl shadow-md">
                🎂
            </div>
        </div>

        <h1 class="text-3xl font-bold text-gray-800 mb-2">Happy Birthday!</h1>
        <h2 class="text-xl font-semibold text-purple-600 mb-6">[ใส่ชื่อเจ้าของวันเกิด]</h2>

        <button 
            id="wishButton"
            class="bg-gradient-to-r from-purple-500 to-pink-500 text-white font-medium py-3 px-8 rounded-full shadow-lg hover:shadow-xl hover:from-purple-600 hover:to-pink-600 transition-all active:scale-95"
            onclick="showWishes()"
        >
            แตะเพื่อดูคำอวยพร 🎁
        </button>

        <div id="wishesText" class="reveal-text mt-8 text-gray-600 leading-relaxed">
            <p class="mb-3">ขอให้ปีนี้เป็นปีที่ยอดเยี่ยม มีแต่รอยยิ้มและความสุขในทุกๆ วัน</p>
            <p class="mb-3">คิดหวังสิ่งใดก็ขอให้สมปรารถนา สุขภาพร่างกายแข็งแรงนะ!</p>
            <p class="font-semibold text-gray-800 mt-4">จาก ... [ชื่อของคุณ]</p>
        </div>

    </div>

    <script>
        function showWishes() {
            // 1. ซ่อนปุ่ม
            document.getElementById('wishButton').style.display = 'none';
            // 2. แสดงข้อความ
            document.getElementById('wishesText').style.display = 'block';
            
            // 3. จุดพลุ Confetti
            var duration = 3 * 1000;
            var animationEnd = Date.now() + duration;
            var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 0 };

            function randomInRange(min, max) {
                return Math.random() * (max - min) + min;
            }

            var interval = setInterval(function() {
                var timeLeft = animationEnd - Date.now();

                if (timeLeft <= 0) {
                    return clearInterval(interval);
                }

                var particleCount = 50 * (timeLeft / duration);
                confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
                confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
            }, 250);
        }
    </script>
</body>
</html>
